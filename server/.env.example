# ------------------------------------------------------------
# VidAsk AI Backend Environment Example
# Copy this file to .env and fill in the values for your setup.
# ------------------------------------------------------------

# App
NODE_ENV=development
PORT=3000
WEB_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database
DB_URL=mongodb://localhost:27017/vidask

# AI Provider
# local = deterministic fallback without paid AI calls
# openai = use OpenAI for summaries and Q&A
AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Upload Limits
MAX_UPLOADED_VIDEOS=10
MAX_VIDEO_UPLOAD_MB=500

# Redis Runtime Cache
# memory = local in-process cache
# redis = Redis hot runtime memory for summaries, chunks, topics, and session state
CACHE_PROVIDER=memory
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=vidask
VIDEO_RUNTIME_CACHE_TTL_SECONDS=1800

# BullMQ Background Jobs
# none = no background queue
# bullmq = enqueue slow video processing jobs in Redis/BullMQ
QUEUE_PROVIDER=none
BULLMQ_REDIS_URL=redis://localhost:6379
VIDEO_PROCESSING_QUEUE_NAME=video-processing
VIDEO_PROCESSING_JOB_ATTEMPTS=3
VIDEO_PROCESSING_JOB_BACKOFF_MS=5000

# Storage
# local = store uploaded video files on server disk
# gcs = store uploaded video files in Google Cloud Storage
STORAGE_PROVIDER=local

# Google Cloud Storage
# Required only when STORAGE_PROVIDER=gcs
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# Use either GCS_KEY_FILE or GCS_CLIENT_EMAIL + GCS_PRIVATE_KEY
GCS_KEY_FILE=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=

# GCS object path and playback URL behavior
GCS_UPLOAD_PREFIX=vidask/videos
GCS_PUBLIC_BASE_URL=
GCS_SIGNED_URL_TTL_SECONDS=900
